/**
 * SenseCAP Indicator Motion App
 *
 * Links up to 16 Hubitat motion, contact, water, or smoke sensors to a SenseCAP Indicator display.
 *
 * Motion sensor:   active    → RED  |  inactive  → fades to GREEN
 * Contact sensor:  open      → RED  |  closed    → fades to CYAN
 * Water sensor:    wet       → RED  |  dry       → fades to BLUE
 * Smoke sensor:    detected  → RED  |  clear     → fades to YELLOW
 *
 * Author: jlslate (slate)
 * Version: 2.3.0  — fix icon codepoints to confirmed openHASP built-in subset
 */

definition(
    name: "SenseCAP Indicator Motion",
    namespace: "community",
    author: "jlslate (slate)",
    description: "Shows motion, contact, water, and smoke sensor states on a SenseCAP Indicator display via MQTT",
    category: "Integration",
    iconUrl: "",
    iconX2Url: "",
    singleInstance: false
)

preferences {
    page(name: "mainPage")
}

def mainPage() {
    dynamicPage(name: "mainPage", title: "SenseCAP Indicator MQTT simplified", install: true, uninstall: true) {

        section("<b>App Name</b>") {
            label title: "Rename this app (optional)", required: false
        }

        section("<b>SenseCAP Indicator Device</b>") {
            input name: "indicatorDevice",
                type: "capability.actuator",
                title: "Select your SenseCAP Indicator device",
                required: true,
                multiple: false
        }

        section("<b>Display Layout</b>") {
            input name: "gridLayout",
                type: "enum",
                title: "Grid Layout",
                options: [
                    "2x2": "2×2 (4 sensors)",
                    "3x3": "3×3 (9 sensors)",
                    "4x4": "4×4 (16 sensors)"
                ],
                defaultValue: "2x2",
                required: true,
                submitOnChange: true
        }

        int maxSlots = maxSlots()

        section("<b>Sensor → Display Object Mapping</b>") {
            paragraph "For each slot choose the sensor type, assign a device, and set a label."

            (1..maxSlots).each { idx ->
                String typeKey = "sensorType${idx}"
                String type    = settings[typeKey] ?: "motion"

                paragraph "<hr><b>Slot ${idx}</b>", width: 12

                input name: typeKey,
                    type: "enum",
                    title: "Slot ${idx} — Sensor Type",
                    options: ["motion": "Motion sensor", "contact": "Contact sensor", "water": "Water sensor", "smoke": "Smoke sensor"],
                    defaultValue: "motion",
                    required: true,
                    submitOnChange: true,
                    width: 4

                if (type == "contact") {
                    input name: "sensor${idx}",
                        type: "capability.contactSensor",
                        title: "Slot ${idx} — Contact Sensor",
                        required: false,
                        multiple: false,
                        width: 4
                } else if (type == "water") {
                    input name: "sensor${idx}",
                        type: "capability.waterSensor",
                        title: "Slot ${idx} — Water Sensor",
                        required: false,
                        multiple: false,
                        width: 4
                } else if (type == "smoke") {
                    input name: "sensor${idx}",
                        type: "capability.smokeDetector",
                        title: "Slot ${idx} — Smoke Sensor",
                        required: false,
                        multiple: false,
                        width: 4
                } else {
                    input name: "sensor${idx}",
                        type: "capability.motionSensor",
                        title: "Slot ${idx} — Motion Sensor",
                        required: false,
                        multiple: false,
                        width: 4
                }

                input name: "label${idx}",
                    type: "text",
                    title: "Slot ${idx} — Label",
                    defaultValue: "Sensor ${idx}",
                    required: false,
                    width: 3

                input name: "icon${idx}",
                    type: "enum",
                    title: "Slot ${idx} — Icon",
                    options: mdiOptionsFor(type),
                    defaultValue: "none",
                    required: false,
                    submitOnChange: false,
                    width: 3
            }
        }

        section("<b>Options</b>") {
            input name: "syncOnStartup",
                type: "bool",
                title: "Sync all sensor states to display on startup / save",
                defaultValue: true,
                description: "Recommended — keeps display accurate after a hub reboot"

            input name: "logLevel",
                type: "enum",
                title: "Logging Level",
                options: [
                    "0": "None",
                    "1": "Info only",
                    "2": "Info + Debug"
                ],
                defaultValue: "1",
                required: true
        }

        section("<b>Status</b>") {
            paragraph "Sensors configured: <b>${subscribedCount()}</b>"
            if (indicatorDevice) {
                paragraph "Indicator MQTT status: <b>${indicatorDevice.currentValue('mqttStatus') ?: 'unknown'}</b>"
            }
        }
    }
}

// ── Lifecycle ────────────────────────────────────────────────────────────────

def installed() {
    infoLog "[SensorDisplay] Installed"
    initialize()
}

def updated() {
    infoLog "[SensorDisplay] Updated"
    unsubscribe()
    initialize()
}

def uninstalled() {
    unsubscribe()
}

def initialize() {
    (1..16).each { idx ->
        def dev  = settings["sensor${idx}"]
        String t = settings["sensorType${idx}"] ?: "motion"
        if (dev) {
            if (t == "contact") {
                subscribe(dev, "contact", "contactHandler${idx}")
            } else if (t == "water") {
                subscribe(dev, "water", "waterHandler${idx}")
            } else if (t == "smoke") {
                subscribe(dev, "smoke", "smokeHandler${idx}")
            } else {
                subscribe(dev, "motion", "motionHandler${idx}")
            }
        }
    }

    if (settings.syncOnStartup) {
        runIn(6, syncAllSensors)
    }

    // Push labels and slot types to display
    if (settings.indicatorDevice) {
        int maxChars = (settings.gridLayout == "4x4") ? 7 : (settings.gridLayout == "3x3") ? 11 : 16
        def labels    = [:]
        def slotTypes = [:]
        (1..maxSlots()).each { idx ->
            String raw = (settings["label${idx}"] ?: "Sensor ${idx}").toString()
            labels[idx]    = buildLabel(idx, raw, maxChars)
            slotTypes[idx] = settings["sensorType${idx}"] ?: "motion"
        }
        settings.indicatorDevice.updateLabels(labels)
        settings.indicatorDevice.updateSlotTypes(slotTypes)
    }

    unschedule(updateInfoObjects)
    unschedule(waitForMqttThenUpdate)

    // Re-sync all sensor states whenever the SenseCAP display reboots
    if (settings.indicatorDevice) {
        subscribe(settings.indicatorDevice, "displayRebooted", displayRebootedHandler)
    }

    infoLog "[SensorDisplay] Initialized — ${subscribedCount()} sensor(s) subscribed"
}

